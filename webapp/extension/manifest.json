{
  "manifest_version": 3,
  "name": "Laminar.AI Recorder",
  "version": "0.1.0",
  "description": "Logs tab switches and confusion captures for Laminar.AI.",
  "permissions": ["tabs", "storage", "downloads", "activeTab", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Laminar.AI Recorder",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
