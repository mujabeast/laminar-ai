OPENAI_API_KEY=your_openai_api_key_here
OPENAI_RESPONSES_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Azure OpenAI alternative:
# Set OPENAI_BASE_URL to something like:
# https://YOUR-RESOURCE.openai.azure.com/openai/v1
# and either reuse OPENAI_API_KEY or set AZURE_OPENAI_API_KEY instead.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=

# Optional: add current pricing for your chosen model if you want approximate
# cost logging in the server console for each AI request.
OPENAI_INPUT_COST_PER_1M_TOKENS=
OPENAI_OUTPUT_COST_PER_1M_TOKENS=
